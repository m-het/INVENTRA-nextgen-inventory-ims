// IMS Backend - Prisma schema for PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  INVENTORY_MANAGER
  WAREHOUSE_STAFF
}

enum MovementType {
  INBOUND
  OUTBOUND
  TRANSFER
  ADJUSTMENT
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

enum GRNStatus {
  DRAFT
  CONFIRMED
}

enum PickListStatus {
  PENDING
  IN_PROGRESS
  DISPATCHED
}

enum StockCountStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         Role      @default(WAREHOUSE_STAFF)
  name         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]
  stockMovements StockMovement[] @relation("CreatedBy")
  purchaseOrders PurchaseOrder[] @relation("CreatedBy")
  grns         Grn[]     @relation("ReceivedBy")
  pickLists    PickList[] @relation("AssignedTo")
  stockCounts  StockCount[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model PasswordResetOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  code      String?   @unique
  parentId  String?   @map("parent_id")
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
}

model Product {
  id            String    @id @default(cuid())
  sku           String    @unique
  name          String
  categoryId    String?   @map("category_id")
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unitOfMeasure String?   @map("unit_of_measure")
  barcode       String?   @unique
  description   String?
  reorderLevel  Int       @default(0) @map("reorder_level")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  stockLevels   StockLevel[]
  stockMovements StockMovement[]
  poLines      POLine[]
  grnLines     GrnLine[]
  pickListLines PickListLine[]
  stockCountLines StockCountLine[]
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String?
  bins      Bin[]
  stockLevels StockLevel[]
  stockMovementsFrom StockMovement[] @relation("FromLocation")
  stockMovementsTo   StockMovement[] @relation("ToLocation")
  stockCounts StockCount[]
}

model Bin {
  id          String   @id @default(cuid())
  warehouseId String   @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  code        String
  name        String?
  stockLevels StockLevel[]
  grnLines    GrnLine[]
  pickListLines PickListLine[]
  stockCountLines StockCountLine[]
  @@unique([warehouseId, code])
}

model StockLevel {
  id              String    @id @default(cuid())
  productId       String    @map("product_id")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  locationId      String    @map("location_id")
  location        Warehouse @relation(fields: [locationId], references: [id], onDelete: Cascade)
  binId           String?   @map("bin_id")
  bin             Bin?      @relation(fields: [binId], references: [id], onDelete: SetNull)
  quantity        Int       @default(0)
  reservedQuantity Int     @default(0) @map("reserved_quantity")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  @@unique([productId, locationId, binId])
}

model StockMovement {
  id              String       @id @default(cuid())
  type            MovementType
  productId       String       @map("product_id")
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromLocationId  String?      @map("from_location_id")
  fromLocation    Warehouse?   @relation("FromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocationId    String?      @map("to_location_id")
  toLocation      Warehouse?   @relation("ToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  quantity        Int
  referenceType   String?      @map("reference_type")
  referenceId     String?      @map("reference_id")
  createdById     String?      @map("created_by")
  createdBy       User?        @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  code         String?  @unique
  contactEmail String? @map("contact_email")
  contactPhone String? @map("contact_phone")
  address      Json?
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  supplierId  String    @map("supplier_id")
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  status      POStatus  @default(DRAFT)
  orderNumber String    @unique @map("order_number")
  orderedAt   DateTime? @map("ordered_at")
  expectedAt  DateTime? @map("expected_at")
  createdById String?   @map("created_by")
  createdBy   User?     @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lines       POLine[]
  grns        Grn[]
}

model POLine {
  id                String   @id @default(cuid())
  poId              String   @map("po_id")
  po                PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId         String   @map("product_id")
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantityOrdered   Int      @map("quantity_ordered")
  quantityReceived  Int      @default(0) @map("quantity_received")
  unitPrice         Decimal? @map("unit_price") @db.Decimal(12, 2)
}

model Grn {
  id          String     @id @default(cuid())
  poId        String     @map("po_id")
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Restrict)
  receivedAt  DateTime?  @map("received_at")
  receivedById String?   @map("received_by")
  receivedBy  User?      @relation("ReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  status      GRNStatus  @default(DRAFT)
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  lines       GrnLine[]
}

model GrnLine {
  id                String   @id @default(cuid())
  grnId              String   @map("grn_id")
  grn                Grn      @relation(fields: [grnId], references: [id], onDelete: Cascade)
  productId          String   @map("product_id")
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantityExpected   Int      @map("quantity_expected")
  quantityReceived   Int      @default(0) @map("quantity_received")
  binId              String?  @map("bin_id")
  bin                Bin?     @relation(fields: [binId], references: [id], onDelete: SetNull)
}

model PickList {
  id          String         @id @default(cuid())
  orderRef    String?        @map("order_ref")
  status      PickListStatus @default(PENDING)
  assignedToId String?      @map("assigned_to")
  assignedTo  User?          @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now()) @map("created_at")
  dispatchedAt DateTime?     @map("dispatched_at")
  lines       PickListLine[]
}

model PickListLine {
  id            String    @id @default(cuid())
  pickListId    String    @map("pick_list_id")
  pickList      PickList  @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  productId     String    @map("product_id")
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity      Int
  quantityPicked Int      @default(0) @map("quantity_picked")
  binId        String?   @map("bin_id")
  bin          Bin?      @relation(fields: [binId], references: [id], onDelete: SetNull)
}

model StockCount {
  id          String           @id @default(cuid())
  locationId  String           @map("location_id")
  location    Warehouse        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  status      StockCountStatus @default(DRAFT)
  countedById String?          @map("counted_by")
  countedBy   User?            @relation(fields: [countedById], references: [id], onDelete: SetNull)
  countedAt   DateTime?        @map("counted_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  completedAt DateTime?        @map("completed_at")
  lines       StockCountLine[]
}

model StockCountLine {
  id              String     @id @default(cuid())
  stockCountId    String     @map("stock_count_id")
  stockCount      StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  productId       String     @map("product_id")
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  binId           String?    @map("bin_id")
  bin             Bin?       @relation(fields: [binId], references: [id], onDelete: SetNull)
  systemQuantity  Int        @map("system_quantity")
  countedQuantity Int?       @map("counted_quantity")
  variance        Int?
  countedAt       DateTime?  @map("counted_at")
}

model IntegrationsConfig {
  id        String   @id @default(cuid())
  provider  String   @unique
  apiKey    String?  @map("api_key")
  webhookUrl String? @map("webhook_url")
  config    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}
